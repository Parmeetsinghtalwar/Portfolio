# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# LinkedIn OAuth — SocialHub demo on /projects/socialhub
# App: https://www.linkedin.com/developers/
# Products: Sign In with LinkedIn + Share on LinkedIn (w_member_social)
# Redirect: http://localhost:3001/api/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3001/api/oauth/linkedin/callback
LINKEDIN_SESSION_SECRET=

# Cloudinary — CDN for images & video (server upload + delivery)
# Dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=portfolio
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# OpenRouter — contact transcribe + project image generation script
OPENROUTER_API_KEY=
# Alias also supported by scripts:
# OPEN_ROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
OPENROUTER_TEXT_MODEL=openai/gpt-4.1-mini
# openai/gpt-image-1 (via tool) or google/gemini-2.5-flash-image
OPENROUTER_IMAGE_MODEL=openai/gpt-image-1
OPENROUTER_TOOL_MODEL=openai/gpt-4o-mini
