# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# LinkedIn OAuth — SocialHub demo on /projects/socialhub
# App: https://www.linkedin.com/developers/
# Products: Sign In with LinkedIn + Share on LinkedIn (w_member_social)
# Redirect: http://localhost:3001/api/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3001/api/oauth/linkedin/callback
LINKEDIN_SESSION_SECRET=

# Cloudinary — CDN for images & video (server upload + delivery)
# Dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=portfolio
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Optional: AI transcribe on contact save
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
